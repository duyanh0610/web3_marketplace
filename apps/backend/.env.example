DATABASE_URL=postgresql://postgres:postgres@localhost:5432/we3_marketplace?schema=public
# Port 6379 is docker-compose's default; infrastructure/docker-compose.yml
# maps to 6380 on this dev machine to avoid a conflict with an unrelated
# Redis container from another project — adjust to match your own setup.
REDIS_URL=redis://localhost:6379
PORT=4000
JWT_SECRET=
# Must match the frontend's actual origin exactly (scheme+host+port) —
# enables CORS so browser fetches from the frontend aren't blocked.
FRONTEND_URL=http://localhost:3000

# Pinata account API keys (Pinata dashboard → API Keys → create key with
# pinFileToIPFS + pinJSONToIPFS scopes) — used by MetadataModule to pin
# mint images/metadata to IPFS. See docs/milestones/milestone-03-metadata-ipfs.md.
PINATA_API_KEY=
PINATA_SECRET=
# Same Pinata API key, JWT form — required for the v3 Files API (pin-status
# polling in PinataPinStatusChecker); the legacy key/secret headers above
# are rejected by that endpoint (401). Pinata dashboard → API Keys → JWT.
PINATA_JWT=
