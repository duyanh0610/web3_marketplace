DATABASE_URL=postgresql://postgres:postgres@localhost:5432/we3_marketplace?schema=public
# Port 6379 is docker-compose's default; infrastructure/docker-compose.yml
# maps to 6380 on this dev machine to avoid a conflict with an unrelated
# Redis container from another project — adjust to match your own setup.
REDIS_URL=redis://localhost:6379
SEPOLIA_RPC_URL=
# WebSocket RPC, used only for live mode's new-block subscription (falls
# back to polling if unset/unreachable — see docs/08-blockchain-indexer.md §3).
SEPOLIA_WS_RPC_URL=
INDEXER_CONFIRMATIONS=5
# Earlier of the MarketplaceNFT/Marketplace contract deployment blocks on
# Sepolia — find via Etherscan's "Contract Creation" tx for each address.
INDEXER_START_BLOCK=
INDEXER_BACKFILL_BLOCK_RANGE=5000
# How many blocks of per-block hash history to retain for reorg detection —
# must be well beyond INDEXER_CONFIRMATIONS (see docs/08-blockchain-indexer.md §4).
INDEXER_REORG_CHECK_DEPTH=20
# How often live mode falls back to polling (ms) when the websocket
# subscription is down.
INDEXER_POLL_INTERVAL_MS=15000
