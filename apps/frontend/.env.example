# Required even for a build to succeed (RainbowKit validates non-empty at
# render time, including static generation) — get a free one at
# https://cloud.walletconnect.com. A placeholder value unblocks local builds
# but real wallet-connect functionality needs a real project ID.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
NEXT_PUBLIC_SEPOLIA_RPC_URL=
NEXT_PUBLIC_GRAPHQL_API_URL=http://localhost:4000/graphql
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
